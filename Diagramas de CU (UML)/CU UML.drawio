        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle AUTENTICACIÓN Y SEGURIDAD\nleft to right direction\n\nactor Cliente\nactor Administrador\n\nrectangle \&quot;Sistema Portal Cliente\&quot; {\n\n  usecase \&quot;CU-01\\nIniciando sesión y redirigiendo al Portal Cliente\&quot; as CU01\n  usecase \&quot;CU-02\\nCerrando sesión activa\&quot; as CU02\n  usecase \&quot;CU-03\\nSolicitando recuperación de contraseña\&quot; as CU03\n  usecase \&quot;CU-04\\nRegistrando cuenta nueva\&quot; as CU04\n  usecase \&quot;CU-05\\nBloqueando IP por intentos fallidos de inicio de sesión\&quot; as CU05\n  usecase \&quot;CU-06\\nRevisando historial de IPs bloqueadas por intentos fallidos\&quot; as CU06\n  usecase \&quot;CU-10\\nCambiando contraseña de acceso al portal\&quot; as CU10\n  usecase \&quot;CU-11\\nValidando requisitos de complejidad de contraseña\&quot; as CU11\n  usecase \&quot;CU-12\\nCerrando sesión automáticamente por inactividad\&quot; as CU12\n\n}\n\nCliente --&gt; CU01\nCliente --&gt; CU02\nCliente --&gt; CU03\nCliente --&gt; CU04\nCliente --&gt; CU05\nCliente --&gt; CU10\nCliente --&gt; CU12\n\nAdministrador --&gt; CU06\n\nCU03 ..&gt; CU11 : &lt;&lt;include&gt;&gt;\nCU04 ..&gt; CU11 : &lt;&lt;include&gt;&gt;\nCU10 ..&gt; CU11 : &lt;&lt;include&gt;&gt;\n\nCU05 ..&gt; CU01 : &lt;&lt;extend&gt;&gt;\nCU12 ..&gt; CU02 : &lt;&lt;extend&gt;&gt;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="mv0_7yHzDzH2L54vvPRJ-1">
